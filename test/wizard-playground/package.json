{
  "name": "wizard-playground",
  "version": "0.0.1",
  "description": "Playground for testing the @stencil/vitest wizard via STENCIL_WIZARD_DEV",
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "stencil build",
    "dev": "stencil build --dev --watch --serve",
    "generate": "stencil generate",
    "wizard:init-dev": "STENCIL_WIZARD_DEV=../../dist/wizard.js stencil init",
    "wizard:add-dev": "STENCIL_WIZARD_DEV=../../dist/wizard.js stencil add",
    "test": "stencil-test",
    "test:unit": "vitest run --project unit",
    "test:browser": "stencil-test --project browser",
    "test:jsdom": "stencil-test --project jsdom",
    "test:happy": "vitest run --project happy"
  },
  "devDependencies": {
    "@stencil/vitest": "workspace:*",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "happy-dom": "^20.10.2",
    "jsdom": "^27.3.0",
    "playwright": "^1.57.0",
    "vitest": "^4.1.8"
  },
  "collection": "./dist/collection/collection-manifest.json",
  "private": true,
  "type": "module",
  "dependencies": {
    "@stencil/core": "5.0.0-alpha.8"
  },
  "pnpm": {
    "overrides": {
      "@stencil/core": "5.0.0-alpha.8"
    }
  },
  "module": "./dist/standalone/index.js",
  "types": "./dist/types/standalone.d.ts"
}
